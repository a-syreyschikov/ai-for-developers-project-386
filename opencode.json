{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "primevue": {
      "type": "local",
      "command": ["node", "./node_modules/@primevue/mcp/dist/index.js"],
      "cwd": ".",
      "enabled": true,
      "timeout": 30000
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": true
    }
  }
}
